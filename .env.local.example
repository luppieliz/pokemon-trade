# ------------------------------------------------------------------
# Copy this file to ".env.local" and fill in your own values.
# .env.local is git-ignored, so your secrets never get committed.
# ------------------------------------------------------------------

# JustTCG API key (free tier) -> https://justtcg.com/
# REQUIRED: provides live market prices for both Japanese and English cards.
JUSTTCG_API_KEY=

# Telegram bot (see README for step-by-step setup) -----------------
# 1. Message @BotFather on Telegram, send /newbot, copy the token here.
TELEGRAM_BOT_TOKEN=
# 2. The chat that should receive secured deals (your user id, or a
#    group/channel id). README explains how to find it.
TELEGRAM_CHAT_ID=

# Password for the /admin page where YOU list cards for trade.
# Anyone with this password can add/remove listings, so keep it secret.
ADMIN_PASSWORD=change-me

# "Buy directly" markup over live market price.
#   10   -> flat +S$10 on every card
#   15%  -> +15% of the market price
BUY_MARKUP=10
